# Copy to backend/.env (gitignored) and fill in real values. Never commit .env.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-2

# Shared secret required in the x-api-key header on every request to this backend
API_KEY=

# Origin allowed to call this backend via CORS
FRONTEND_ORIGIN=http://localhost:3001
